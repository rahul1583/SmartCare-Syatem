GOOGLE_CLIENT_ID=your-google-client-id-here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# Site Settings
SITE_ID=1
DEBUG=True
SECRET_KEY=django-insecure-zr(s)mh4z3xq)-k1ufbdo4m0caeo3!-s0azmu39am0wou7ba@e

# Email — pick ONE primary path:
#
# A) Resend (recommended — no Gmail SMTP): https://resend.com → API Keys → copy key
#    Leave RESEND_FROM_EMAIL as onboarding@resend.dev for quick tests, or verify your domain.
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=onboarding@resend.dev
#
# B) Gmail SMTP: App Password only (not your normal password). 2-Step Verification ON.
#
# Local dev: if sending fails while DEBUG=True, the OTP is shown on the verify page (no blocking error).
# Set EMAIL_DEV_OTP_FALLBACK=false to disable that and always show errors instead.
EMAIL_DEV_OTP_FALLBACK=true

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-16-char-app-password
DEFAULT_FROM_EMAIL=your-email@gmail.com
# Alternative if 587 fails on your network:
# EMAIL_PORT=465
# EMAIL_USE_TLS=False
# EMAIL_USE_SSL=True
